# Server Configurations
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database Configurations
MONGODB_URI=mongodb://localhost:27017/gft-db

# JWT Configuration
JWT_SECRET=super_secret_jwt_access_key_change_me
JWT_REFRESH_SECRET=super_secret_jwt_refresh_key_change_me
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Redis Configuration (Optional: system falls back to memory cache if empty)
REDIS_URL=redis://127.0.0.1:6379

# Cloudinary Credentials (For KYC and Document uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# SMTP Email Configuration (Nodemailer)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="Green Future Tech" <no-reply@greenfuturetech.com>

# System Super Admin Initialization (Automatically seeded on boot if database is empty)
INIT_SUPERADMIN_EMAIL=superadmin@greenfuturetech.com
INIT_SUPERADMIN_PASS=AdminPass123!
